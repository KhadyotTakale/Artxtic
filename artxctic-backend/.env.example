# Application Settings
APP_NAME=Artxtic Backend
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/artxtic
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# JWT & Security
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie Settings
COOKIE_DOMAIN=
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# AWS SES SMTP Configuration
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Artxtic

# Cloudflare R2 Storage Configuration
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=artxtic-dev
R2_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com
PRESIGNED_URL_EXPIRATION=3600

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Fal.ai Configuration
FAL_API_KEY=your-fal-api-key

# Dodopayments Configuration
DODOPAYMENTS_API_KEY=your-dodo-api-key
DODOPAYMENTS_WEBHOOK_SECRET=your-dodo-webhook-secret

# Snowflake ID Configuration
WORKER_ID=1
DATACENTER_ID=1

# CORS Settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
